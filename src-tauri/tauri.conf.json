{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ire",
  "version": "0.1.0",
  "identifier": "com.ire.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ire",
        "width": 1280,
        "height": 820,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzNTI1NTQxMzhBRTcxODMKUldTRGNhNDRRVlZTMDhQSnZkNnNzSkJ3QUF5K3FGSXZJdUNFZGlZUGpDbGIxdXV6dzQwT2dLVUUK",
      "endpoints": [
        "https://github.com/giacomo-ciro/ire/releases/latest/download/latest.json"
      ]
    }
  }
}
