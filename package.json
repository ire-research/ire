{
  "name": "ire",
  "private": true,
  "version": "0.0.0",
  "description": "The first general-purpose Integrated Research Environment (IRE) — a local-first desktop environment for ML researchers.",
  "license": "MIT",
  "author": "Giacomo Cirò and Vittorio Rossi",
  "homepage": "https://github.com/ire-research/ire#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ire-research/ire.git"
  },
  "bugs": {
    "url": "https://github.com/ire-research/ire/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:tauri": "env -u GTK_PATH -u GTK_EXE_PREFIX -u GTK_IM_MODULE_FILE -u GDK_PIXBUF_MODULEDIR -u GDK_PIXBUF_MODULE_FILE -u GIO_MODULE_DIR -u GSETTINGS_SCHEMA_DIR -u LOCPATH npm run tauri -- dev"
  },
  "dependencies": {
    "@fontsource/syne": "^5.2.7",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "geist": "^1.0.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
